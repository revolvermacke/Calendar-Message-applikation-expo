  "main": "index.ts",
  "scripts": {
    "start": "npm run start:dev",
    "dev": "npm run start:dev",
    "start:dev": "cross-env APP_ENV=development expo start",
    "start:prod": "cross-env APP_ENV=production expo start",
    "android": "npm run android:dev",
    "android:dev": "cross-env APP_ENV=development expo start --android",
    "android:prod": "cross-env APP_ENV=production expo start --android",
    "ios": "npm run ios:dev",
    "ios:dev": "cross-env APP_ENV=development expo start --ios",
    "ios:prod": "cross-env APP_ENV=production expo start --ios",
    "web": "npm run web:dev",
    "web:dev": "cross-env APP_ENV=development expo start --web",
    "web:prod": "cross-env APP_ENV=production expo start --web"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-calendar": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.17",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
